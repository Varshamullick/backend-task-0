# Database Configuration
# Use local MongoDB for development:
MONGODB_URI=mongodb://localhost:27017/scalable-api
# Or use MongoDB Atlas (replace username,password,database):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.if1daae.mongodb.net/<database>?retryWrites=true&w=majority
DB_NAME=scalable-api

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# API Documentation
SWAGGER_ENABLED=true

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Admin Default Credentials (for seeding)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=AdminPassword123!
